# --- GLOBAL NUCLEAR IGNORES ---
.env
.env.*
# Stop EVERYTHING in these folders everywhere
**/venv/
venv/
.venv/
env/
**/node_modules/
**/dist/
**/build/
.next/
out/

# Python / Compiled caches
**/__pycache__/
*.py[cod]
*$py.class

# LARGE ARCHIVES
*.zip
*.rar
*.7z
*.tar
*.gz
*.iso

# Data & Models (Strict)
data/
**/data/**
models/
**/models/**
*.csv
*.parquet
*.h5
*.txt
*.pth
*.joblib
*.pkl
*.onnx

# IDE & Logs
.vscode/
.idea/
.ipynb_checkpoints/
.DS_Store
reports/
logs/
*.log

# --- PROJECT ROOTS (Explicit Override) ---
# Allow your actual project code
!src/
!dashboard/
!README.md
!.gitignore

# Explicitly re-ignore dashboard internal noise
dashboard/node_modules/
dashboard/dist/
dashboard/.env*